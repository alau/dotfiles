#!/bin/bash
set -euo pipefail

read -r -d '' BASE << 'BASEJSON' || true
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "sandbox": {
    "enable": true
  },
  "respectGitignore": true,
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(go test *)",
      "Bash(go build *)",
      "Bash(go vet *)",
      "Bash(go run *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(ls *)",
      "Bash(which *)",
      "Bash(git stash list*)",
      "Bash(git remote*)",
      "Bash(git tag*)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(type *)",
      "WebSearch",
      "WebFetch",
      "mcp__github__get_me",
      "mcp__github__get_file_contents",
      "mcp__github__get_commit",
      "mcp__github__search_code",
      "mcp__github__search_repositories",
      "mcp__github__search_issues",
      "mcp__github__search_pull_requests",
      "mcp__github__list_issues",
      "mcp__github__list_pull_requests",
      "mcp__github__list_commits",
      "mcp__github__list_branches",
      "mcp__github__list_tags",
      "mcp__github__list_releases",
      "mcp__github__issue_read",
      "mcp__github__pull_request_read",
      "mcp__clickup__clickup_get_task",
      "mcp__clickup__clickup_filter_tasks",
      "mcp__clickup__clickup_get_custom_fields"
    ],
    "deny": [
      "Read(./.env)"
    ],
    "defaultMode": "plan"
  },
  "model": "opusplan",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "effortLevel": "max",
  "vimMode": true,
  "lspDiagnostics": {
    "enabled": true,
    "languages": [
      "python",
      "go",
      "lua"
    ]
  },
  "hooks": {
    "PreToolUse": [{
      "matcher": "Bash",
      "hooks": [{ "type": "command",
        "command": "/home/alau/.claude/hooks/rtk-rewrite.sh"
      }]
    }]
  },
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  }
}
BASEJSON

LOCAL="$HOME/.claude/settings.local.json"

if [ -f "$LOCAL" ]; then
  printf '%s' "$BASE" | jq --slurpfile local "$LOCAL" '. * $local[0]'
else
  printf '%s' "$BASE"
fi
